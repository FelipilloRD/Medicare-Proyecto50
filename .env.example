# ══════════════════════════════════════════════════════════
# MEDICARE AI - ENVIRONMENT VARIABLES
# ══════════════════════════════════════════════════════════

# ── Database Configuration (Supabase PostgreSQL) ──────────
DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
DB_SSL=true

# ── Groq Configuration (IA GRATIS recomendada) ──────────
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MAX_TOKENS=500

# ── OpenAI Configuration (fallback) ───────────────────────
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=500

# ── Server Configuration ────────────────────────
PORT=3002
NODE_ENV=production

# ── Security Configuration ──────────────────────
SESSION_SECRET=your-session-secret-here-change-in-production
CSRF_SECRET=your-csrf-secret-here-change-in-production

# ── Email Configuration (Nodemailer) ────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password-here

# ── Twilio WhatsApp ─────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Clínica (para los templates de notificación) ─
CLINIC_NAME=MediCare AI
CLINIC_PHONE=+1 829 555 0000
CLINIC_EMAIL=info@medicare-ai.com
CLINIC_ADDRESS=Av. Principal 123, Santo Domingo, RD
